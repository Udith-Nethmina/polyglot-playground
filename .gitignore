# ==========================================
# 🌐 Polyglot Playground - Global .gitignore
# ==========================================

# ------------------------------------------
# 💻 Operating System & IDEs
# ------------------------------------------
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# ------------------------------------------
# ☕ Java (JavaFX, Spring, core)
# ------------------------------------------
*.class
*.log
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar
hs_err_pid*
target/
build/
.gradle/
bin/

# ------------------------------------------
# ⚛️ Next.js & Node.js
# ------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.next/
out/
build/
.env.local
.env.development.local
.env.test.local
.env.production.local
.vercel/

# ------------------------------------------
# 🐍 Python
# ------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
venv/
env/
ENV/
.env

# ------------------------------------------
# ⚙️ C++ (Controllers, Arduino, CMake)
# ------------------------------------------
*.o
*.obj
*.out
*.app
*.exe
*.dll
*.so
*.dylib
CMakeCache.txt
CMakeFiles/
CMakeScripts/
Makefile
cmake_install.cmake
install_manifest.txt
compile_commands.json
.clangd/

.pio/
*.hex
*.elf
*.bin